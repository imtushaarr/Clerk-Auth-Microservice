# ============================================================================
# Clerk Authentication Microservice - Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in your values
# ============================================================================

# ============================================================================
# Application Configuration
# ============================================================================

# Application name
APP_NAME=Clerk Auth Microservice

# Application URL - Change to your production domain
# Default: http://localhost:5173
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:5173

# Application port
# Default: 5173
PORT=5173

# Node environment (development, production, test)
# Default: development
NODE_ENV=development

# ============================================================================
# Clerk Authentication Configuration
# REQUIRED - Get these from https://dashboard.clerk.com
# ============================================================================

# Clerk Publishable Key - Public key for frontend authentication
# Format: pk_test_... or pk_live_...
# Get from: https://dashboard.clerk.com/apps/[app-id]/keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Clerk Secret Key - Private key for backend operations
# Format: sk_test_... or sk_live_...
# Get from: https://dashboard.clerk.com/apps/[app-id]/keys
CLERK_SECRET_KEY=sk_test_your_key_here

# Clerk Webhook Secret - For verifying webhook signatures
# Format: whsec_...
# Get from: https://dashboard.clerk.com/apps/[app-id]/webhooks
CLERK_WEBHOOK_SECRET=whsec_your_secret_here

# ============================================================================
# Testmail Email Service Configuration
# OPTIONAL - For email notifications
# Sign up at: https://testmail.app
# ============================================================================

# Enable/disable testmail email service
# Default: true
# Options: true, false
TESTMAIL_ENABLED=true

# Testmail namespace - Your project namespace
# Get from: https://dashboard.testmail.app
TESTMAIL_NAMESPACE=your_namespace_here

# Testmail API Key - For sending emails
# Get from: https://dashboard.testmail.app/settings
TESTMAIL_API_KEY=your_api_key_here

# Testmail API URL - Usually don't need to change
# Default: https://api.testmail.app/api/json
TESTMAIL_API_URL=https://api.testmail.app/api/json

# ============================================================================
# API Rate Limiting Configuration
# ============================================================================

# Auth endpoints rate limit window (milliseconds)
# Default: 900000 (15 minutes)
RATE_LIMIT_AUTH_WINDOW=900000

# Auth endpoints max requests per window
# Default: 5
RATE_LIMIT_AUTH_MAX=5

# General API rate limit window (milliseconds)
# Default: 60000 (1 minute)
RATE_LIMIT_GENERAL_WINDOW=60000

# General API max requests per window
# Default: 100
RATE_LIMIT_GENERAL_MAX=100

# ============================================================================
# CORS Configuration
# ============================================================================

# CORS allowed origins (JSON array format)
# Default: ["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]
# Production example: ["https://yourdomain.com", "https://api.yourdomain.com"]
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8000"]

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (debug, info, warn, error)
# Default: info
LOG_LEVEL=info

# Enable verbose logging
# Default: false
LOG_VERBOSE=false

# ============================================================================
# Webhook Configuration
# ============================================================================

# Clerk webhook URL for local development
# Default: http://localhost:5173/api/webhooks/clerk
# Production: https://yourdomain.com/api/webhooks/clerk
CLERK_WEBHOOK_URL=http://localhost:5173/api/webhooks/clerk

# ============================================================================
# IMPORTANT SETUP INSTRUCTIONS
# ============================================================================
# 1. Create a Clerk account at https://clerk.com
# 2. Create a new application
# 3. Copy your publishable key (NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY)
# 4. Copy your secret key (CLERK_SECRET_KEY)
# 5. Create a webhook endpoint for user.created events:
#    - URL: http://localhost:5173/api/webhooks/clerk (development)
#    - Events: user.created
#    - Copy the webhook secret (CLERK_WEBHOOK_SECRET)
# 6. Create a testmail.app account at https://testmail.app
# 7. Copy your namespace and API key
# 8. Update this file with your values
# 9. Rename to .env.local
# 10. Run: npm install && npm run dev
#
# For production deployment:
# - Change NEXT_PUBLIC_APP_URL to your domain
# - Use production keys from Clerk (pk_live_* and sk_live_*)
# - Update CORS_ORIGINS with your production domains
# - Use HTTPS URLs for webhooks
# ============================================================================
